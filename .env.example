# Base URL for the Hooshinu backend API (must include the /v1 prefix).
# NOTE: backend is currently plain HTTP, so in dev run the frontend on http too.
NEXT_PUBLIC_API_BASE=http://216.106.187.220/v1

# Origin of the relay SSE endpoint (/relay/stream), which lives at the backend
# ROOT (not under /v1). Optional: defaults to API_BASE minus "/v1". Set only if
# the relay is hosted on a different origin.
# NEXT_PUBLIC_RELAY_BASE=http://216.106.187.220
